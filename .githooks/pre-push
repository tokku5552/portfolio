#!/usr/bin/env bash
set -eu

protected_ref="refs/heads/main"
blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "$protected_ref" ]; then
    blocked=1
    break
  fi
done

if [ "$blocked" = "1" ]; then
  echo >&2 "ERROR: Direct pushes to 'main' are prohibited."
  echo >&2 "       Push your feature branch and open a pull request instead."
  exit 1
fi
exit 0
